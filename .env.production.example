# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=        # REQUIRED — set a strong password
POSTGRES_DB=edi_platform

# Redis
REDIS_PASSWORD=           # Optional but recommended in production

# Encryption (32 bytes = 64 hex chars)
# Generate with: pnpm generate:key
ENCRYPTION_KEY=           # REQUIRED — never reuse dev key in prod

# API
API_PORT=3001

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ORG_ID=       # REQUIRED — your organization ID from DB
